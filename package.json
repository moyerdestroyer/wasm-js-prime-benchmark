{
  "name": "prime-benchmark-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "npm run build-wasm && npm --prefix web run dev",
    "build": "npm run build-wasm && npm --prefix web run build",
    "build-wasm": "npx --yes wasm-pack build ./wasm --target web --out-dir ../web/src/wasm/pkg --out-name prime_wasm",
    "serve": "npm --prefix web run serve"
  },
  "devDependencies": {
    "vite": "^2.0.0",
    "typescript": "^4.0.0"
  },
  "dependencies": {
    "react": "^17.0.0",
    "react-dom": "^17.0.0"
  }
}